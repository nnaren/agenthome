{
  "name": "agenthome",
  "version": "0.1.0",
  "description": "Agent 编排管理桌面应用",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "package:win": "electron-vite build && electron-builder --win --dir",
    "package:linux": "electron-vite build && electron-builder --linux --dir",
    "lint": "eslint src"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-log": "^5.0.0",
    "monaco-editor": "^0.44.0",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.agenthome.app",
    "productName": "AgentHome",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.png"
    }
  }
}
